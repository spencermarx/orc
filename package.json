{
  "name": "orc",
  "version": "0.2.9",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "orc:install": "bash packages/cli/lib/init.sh",
    "build": "nx run-many -t build",
    "test": "NX_DAEMON=false nx run-many -t test --projects=@orc/core,@orc/ui,@orc/tui,@orc/web,@orc/api,@orc/plugins",
    "test:watch": "NX_DAEMON=false nx run-many -t test --projects=@orc/core,@orc/ui,@orc/tui -- --watch",
    "test:e2e": "playwright test",
    "start:tui": "npx tsx packages/tui/src/index.tsx"
  },
  "devDependencies": {
    "@nx/js": "^22.6.1",
    "@playwright/test": "^1.49.0",
    "nx": "22.6.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
