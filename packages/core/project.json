{
  "name": "@orc/core",
  "sourceRoot": "packages/core/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "bun build ./src/index.ts --outdir ./dist --target node --format esm", "cwd": "packages/core" }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "packages/core" }
    }
  }
}
